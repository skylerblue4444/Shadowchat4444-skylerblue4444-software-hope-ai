DATABASE_URL=mysql://root:root@localhost:3306/skycoin444
TRUMP_CONTRACT_ADDRESS=0x...
VITE_TRPC_URL=http://localhost:3000/api/trpc
NODE_ENV=development

# ─── Stripe Payment Keys ──────────────────────────────────────────────────────
# Set STRIPE_PUBLISHABLE_KEY and STRIPE_SECRET_KEY in your real .env file.
# Never commit live secret keys to version control.
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Legacy alias (also accepted by client)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# ─── Plaid (optional bank sync) ───────────────────────────────────────────────
PLAID_CLIENT_ID=replace_me
PLAID_SECRET=replace_me
PLAID_ENV=sandbox

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=replace_me
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── Crypto Payment Receiving Addresses ───────────────────────────────────────
BTC_PAYMENT_ADDRESS=bc1q-your-btc-address-here
EVM_PAYMENT_ADDRESS=0x0000000000000000000000000000000000000000
DOGE_PAYMENT_ADDRESS=DYourDogeAddressHere
XMR_PAYMENT_ADDRESS=YourMoneroAddressHere
USDT_PAYMENT_ADDRESS=0xYourUSDTAddressHere
SKY4444_PAYMENT_ADDRESS=sky4444-your-address-here
SHADOW_PAYMENT_ADDRESS=shadow-your-address-here
TRUMP_PAYMENT_ADDRESS=0xYourTrumpCoinAddressHere

# ─── Free Trial Coins ─────────────────────────────────────────────────────────
# SKY4444 coins granted to every new user on first sign-in (free trial)
FREE_TRIAL_COINS=20000

# ─── ICO / Token Sale ─────────────────────────────────────────────────────────
ICO_ACTIVE=true
ICO_PRICE_USD=0.001
ICO_HARD_CAP=50000000
ICO_SOFT_CAP=5000000
ICO_START_DATE=2026-01-01
ICO_END_DATE=2026-12-31

# ─── Staking / Mining Config ──────────────────────────────────────────────────
STAKING_APY_SKY4444=18
STAKING_APY_SHADOW=12
STAKING_APY_TRUMP=8
MINING_BLOCK_REWARD=50
BURN_RATE_BPS=100

# ─── WebSocket / Live Price Feed ──────────────────────────────────────────────
CRYPTO_WS_URL=wss://stream.binance.com:9443/ws
