# ════════════════════════════════════════════════════════════════════════════
# SKY444 — Production Environment Template
# Copy to `.env` and customize; NEVER commit real secrets.
# ════════════════════════════════════════════════════════════════════════════

# ─── Runtime environment ─────────────────────────────────────────────────
SKY444_ENV=production

# ─── PostgreSQL ──────────────────────────────────────────────────────────
POSTGRES_DB=sky444
POSTGRES_USER=sky444
POSTGRES_PASSWORD=replace_with_strong_password_min_32_chars

# ─── Security secrets ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_openssl_rand_hex_32_output
ENCRYPTION_KEY=replace_with_openssl_rand_hex_32_output

# ─── CORS allowed origins (comma-separated) ──────────────────────────────
CORS_ORIGINS=http://localhost,https://sky444.example.com

# ─── Optional: third-party integrations ──────────────────────────────────
# STRIPE_SECRET_KEY=
# OPENAI_API_KEY=
# SENDGRID_API_KEY=
